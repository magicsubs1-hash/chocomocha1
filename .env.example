# DX Kino backend — production env variables
# Бодит утгыг Fly.io secrets-д тохируулна: fly secrets set KEY=VALUE

# Админ хуудсанд нэвтрэх нууц үг (заавал шаардлагатай production-д)
ADMIN_PASS=

# Хэрэглэгчийн JWT токенд зориулсан secret (санамсаргүй 32+ тэмдэгт)
JWT_SECRET=

# Frontend origin-ууд (таслалаар тусгаарласан)
CORS_ORIGIN=https://chocomocha.site,https://www.chocomocha.site

# Production-д Fly.io автоматаар DATA_DIR=/data, PORT=5000 өгнө — гараар бүү өөрчил
